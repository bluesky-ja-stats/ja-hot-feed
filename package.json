    "@atproto/xrpc": "^0.8.2",
    "@atproto/xrpc-server": "^0.11.3",
    "atingester": "^1.0.2",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "envalid": "^8.2.0",
